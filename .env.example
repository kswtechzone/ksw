# Database (Docker: host = postgres, Local: host = localhost)
DATABASE_URL="postgresql://ksw:your_password@postgres:5432/ksw_website"

# Redis (Docker: host = redis, Local: host = localhost)
REDIS_URL="redis://redis:6379"

# Next.js
NEXT_PUBLIC_APP_URL="https://kswtechzone.com"
NEXT_PUBLIC_API_URL="/api"

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET="change-this-to-a-random-secret"

# SMTP (admin verification email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="KSW TechZone <noreply@kswtechzone.com>"

# Admin alert email (contact form notifications)
ADMIN_EMAIL="admin@example.com"

# Public contact info (displayed on contact page)
NEXT_PUBLIC_CONTACT_EMAIL="hello@kswtechzone.com"
NEXT_PUBLIC_CONTACT_PHONE="+977-9863198323"

# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=ksw
POSTGRES_PASSWORD=your_password
POSTGRES_DB=ksw_website

# Docker
COMPOSE_PROJECT_NAME=ksw
